{
  "name": "@nodearchive/nodearchive",
  "version": "1.0.0",
  "description": "Pack and unpack nar, zip, tar, tgz, tar.gz, and gz archives from one API and CLI for Node.js and Bun.",
  "keywords": [
    "archive",
    "bun",
    "cli",
    "commonjs",
    "esm",
    "gzip",
    "javascript",
    "nar",
    "node",
    "tar",
    "typescript",
    "zip"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist-cjs/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist-cjs/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "nar": "./cli/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nodearchive/nodearchive.git"
  },
  "bugs": {
    "url": "https://github.com/nodearchive/nodearchive/issues"
  },
  "homepage": "https://nodearchive.github.io/nodearchive",
  "files": [
    "cli",
    "dist",
    "dist-cjs",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "clean": "node scripts/cleanBuild/index.js",
    "format": "prettier . --write",
    "build": "npm run clean && node scripts/updateVersion/index.js && tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && node scripts/writeCommonJSPackage/index.js",
    "test:coverage": "npm run build && node test/run-coverage.mjs",
    "test:e2e": "node test/e2e/run.mjs",
    "test": "npm run test:coverage && node test/e2e/run.mjs",
    "bench": "npm run build && node benchmark/bench.js",
    "prepare": "husky",
    "prepublishOnly": "npm run test && npm run bench"
  },
  "c8": {
    "all": true,
    "include": [
      "dist/**/*.js"
    ],
    "exclude": [
      "dist/**/*.d.ts",
      "dist/.types/**/*.js",
      "test/**",
      "benchmark/**",
      "playwright.config.ts"
    ]
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@playwright/test": "^1.58.2",
    "@types/tar-stream": "^3.1.4",
    "@types/node": "^25.4.0",
    "c8": "^11.0.0",
    "husky": "^9.1.7",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@z-base/bytecodec": "^1.1.0",
    "fast-glob": "^3.3.3",
    "jszip": "^3.10.1",
    "tar-stream": "^3.1.8"
  }
}
